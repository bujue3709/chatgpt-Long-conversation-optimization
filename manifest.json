{
  "manifest_version": 3,
  "name": "ChatGPT Conversation Toolkit",
  "version": "1.2.0",
  "description": "Optimize long ChatGPT conversations and export full sessions with one click.",
  "content_scripts": [
    {
      "matches": [
        "https://chat.openai.com/*",
        "https://chatgpt.com/*"
      ],
      "js": [
        "core/state.js",
        "utils/storage.js",
        "utils/dom.js",
        "ui/theme.js",
        "features/search.js",
        "features/timeline.js",
        "features/prompt-library.js",
        "features/collapse.js",
        "features/export.js",
        "ui/toolbar.js",
        "contentScript.js"
      ],
      "css": [
        "styles.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://chat.openai.com/*",
    "https://chatgpt.com/*"
  ]
}
